      "experiment": "Model-output contains relation validation",
      "sci_value": "medium_high",
      "implementation_cost": "medium",
      "why": "Contains policy is strong in expected-json replay but not proven on true model-output raster predictions.",
      "inputs": [
        "reports/vlm/symbol_policy_moe_overlay_p084/p100_precision_at_recall70.jsonl",
        "configs/vlm/contains_relation_policy_p092.json"
