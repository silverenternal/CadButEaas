      "success_gate": [
        "either improves symbol/text materially or documents exclusion with evidence",
        "does not hide negative results"
      ]
    }
  ],
  "minimum_submission_gate": [
    "P111-A completed or a justified smaller locked coverage with reviewer-safe explanation",
    "P111-B completed with at least one credible no-MoE/simple baseline",
    "P111-C at least partial human-reviewed real-raster pilot",
    "All claims in manuscript trace to evidence artifacts and explicit limitations"
  ],
  "recommended_next_task": "SCI-P2-112-full-public-raster-symbol-eval-scout",
  "not_recommended_now": [
    "More handcrafted image-only symbol/text postprocessing",
