      ]
    },
    {
      "rank": 3,
      "id": "P111-C-human-reviewed-real-pilot",
      "experiment": "Human-reviewed real-raster pilot",
      "sci_value": "high",
      "implementation_cost": "human_time",
      "why": "Real-raster evidence is required for credible generalization claims.",
      "inputs": [
        "datasets/annotations/real_scene_graph_pilot_p097c_ai_draft.jsonl",
        "reports/vlm/real_scene_graph_pilot_ai_draft_p097d.md"
