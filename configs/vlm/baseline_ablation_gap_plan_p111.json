      "outputs": [
        "reports/vlm/model_output_contains_relation_eval_p111.json",
        "reports/vlm/model_output_contains_relation_eval_p111.md"
      ],
      "success_gate": [
        "runs on model-output graph rows",
        "reports missing/extra contains",
        "does not promote runtime default unless graph health passes"
      ]
    },
    {
      "rank": 5,
      "id": "P111-E-symbol-ocr-branch-or-scopeout",
      "experiment": "Dedicated symbol/OCR branch or documented failure boundary",
      "sci_value": "medium",
      "implementation_cost": "high_if_training",
      "why": "Image-only symbol/text are weak; either improve them or explicitly scope them out.",
