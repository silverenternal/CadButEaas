      "success_gate": [
        "reports full 992-row or clearly explains unavailable subsets",
        "compares v28/p076/p100 operating points",
        "reports precision/recall/F1/inflation/by-source/by-size"
      ]
    },
    {
      "rank": 2,
      "id": "P111-B-baseline-ablation-matrix",
      "experiment": "Strong baselines and ablations",
      "sci_value": "high",
