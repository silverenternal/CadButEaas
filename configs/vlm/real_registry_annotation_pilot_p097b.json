  "annotation_schema": {
    "record_fields": [
      "record_id",
      "source_dataset",
      "image_path",
      "annotator",
      "review_status"
    ],
    "node_fields": [
      "node_id",
      "family",
      "semantic_type",
      "bbox",
      "confidence_or_quality_flag"
    ],
    "families": [
      "boundary",
      "space",
      "symbol",
      "text"
    ],
    "relation_fields": [
      "source",
      "target",
      "relation",
      "confidence_or_quality_flag"
    ],
    "relations": [
      "contains",
      "bounds",
      "adjacent_to",
      "attached_to",
      "labeled_by"
    ],
    "minimum_required_for_contains_eval": [
      "space nodes with bbox",
      "symbol nodes with bbox",
      "contains relations from space to symbol"
    ],
    "quality_flags": [
      "clear",
      "ambiguous",
      "partial",
      "not_visible",
      "ignore"
    ]
  },
  "annotation_protocol": [
    "Annotate only visible raster evidence; do not use SVG/CAD geometry at annotation time except for later audit comparison.",
    "Draw room/space bbox or polygon proxy sufficient for contains relation evaluation.",
    "Draw symbol fixture/equipment/stair/column/appliance/table/generic_symbol bboxes.",
    "Add contains edges from every room/space to each contained symbol when the symbol belongs to that space.",
    "Mark ambiguous multi-room symbols with quality_flag=ambiguous rather than forcing a single edge.",
    "Double-review at least 20% of pilot records before using as paper evidence."
  ],
  "outputs_to_create_next": [
    "datasets/annotations/real_scene_graph_pilot_p097b.jsonl",
    "reports/vlm/real_scene_graph_pilot_annotation_guide_p097b.md"
  ],
  "claim_boundary": {
    "can_claim_after_annotation": "small external/real-source scene-graph pilot exists for qualitative and limited quantitative validation",
    "cannot_claim": "large-scale cross-dataset generalization until more labels are available"
  }
}
