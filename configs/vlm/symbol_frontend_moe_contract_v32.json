{
  "version": "v32",
  "name": "symbol_frontend_moe_contract",
  "updated": "2026-05-11",
  "scope": "Raster-only symbol frontend MoE for non-vector floorplan recognition.",
  "runtime_contract": {
    "allowed_inputs": [
      "raster image pixels",
      "model weights",
      "runtime configuration",
      "raster-derived candidate fields"
    ],
    "forbidden_inputs": [
      "SVG/parser geometry",
      "CAD vector primitives",
      "expected_json",
      "gold labels",
      "annotation paths",
      "offline semantic ids",
      "oracle match fields"
    ],
    "offline_allowed_uses": [
      "supervised training",
      "locked evaluation",
      "hard-case mining",
      "source-integrity audit"
    ]
  },
  "candidate_set_schema": {
    "required_runtime_fields": [
      "page_id",
      "candidate_id",
      "bbox",
      "score",
      "label",
      "label_id",
      "proposal_source"
    ],
    "optional_runtime_fields": [
      "mask",
      "center_score",
      "selector_score",
      "quality_score",
      "refined_bbox",
      "keep",
      "drop_reason",
      "suppression_reason",
      "expert_trace"
    ],
    "forbidden_runtime_fields": [
      "gold_key",
      "matched_gold_key",
      "best_iou_rank_for_gold",
      "score_rank_for_gold",
      "same_gold_positive_count",
      "same_gold_coverage_count",
      "expected_json",
      "annotation_path",
      "svg_geometry",
      "parser_geometry",
      "semantic_id",
      "oracle_label"
    ]
  },
  "metric_claim_policy": {
    "forbidden": "No single aggregate score may claim frontend progress.",
    "required": [
      "expert-specific metric gates",
      "source_integrity",
      "smoke_or_locked_scope",
      "per-class error buckets",
      "per-size error buckets",
      "runtime_input_integrity"
    ]
  },
