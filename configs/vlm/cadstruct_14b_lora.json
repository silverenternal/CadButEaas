{
  "base_model": "models/vlm/internvl3_5_14b_hf",
  "model_family": "internvl3_5",
  "dataset_jsonl": "datasets/cadstruct/train.jsonl",
  "dev_jsonl": "datasets/cadstruct/dev.jsonl",
  "sft_dataset_jsonl": "datasets/cadstruct_sft/train.jsonl",
  "sft_dev_jsonl": "datasets/cadstruct_sft/dev.jsonl",
  "output_dir": "checkpoints/cadstruct_vl_14b_lora",
  "epochs": 1,
  "max_steps": 100,
  "max_length": 6144,
  "max_image_side": 512,
  "max_vision_tiles": 8,
  "skip_at_max_length": true,
  "skip_oom_samples": true,
  "learning_rate": 0.0001,
  "per_device_train_batch_size": 1,
  "gradient_accumulation_steps": 16,
  "load_in_4bit": true,
  "lora_r": 32,
  "lora_alpha": 64,
  "lora_dropout": 0.05,
  "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"],
  "train_multimodal_projector": true,
  "train_geometry_adapter": false,
  "cuda_visible_devices": "0",
  "notes": [
    "First production-oriented 14B LoRA configuration for CadStruct-VL.",
    "Geometry adapter is kept behind a separate flag so it can be implemented without coupling to the base VLM loader."
  ]
}
